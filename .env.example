# Copy to .env and fill in. The service STARTS WITHOUT any of these (mock DB +
# offline/degraded fallbacks); key-dependent endpoints return clear notes.
# Reviewers run with their own keys.

# --- LLM (copy + vision critic + research extraction), OpenAI-compatible ---
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-5.4-mini
VISION_MODEL=gpt-5.4-mini

# --- Image generation (OpenAI-compatible images endpoint) ---
IMAGE_BASE_URL=
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2

# --- Web search for Tier 1 enrichment (Tavily). Without it, /enrich degrades
#     to clearly-flagged, source-less model knowledge. ---
TAVILY_API_KEY=

# --- Read-only Postgres (provided by reviewers). Without it, a built-in mock
#     of 3 SKUs is used. PRODUCTS_TABLE is optional (else auto-detected). ---
DATABASE_URL=
PRODUCTS_TABLE=
