# Copy to .env and fill in. The service still BOOTS with everything blank
# (mock DB + offline/degraded modes); keys unlock the real pipeline.

# --- LLM (copy / vision critic / research), any OpenAI-compatible gateway ---
LLM_BASE_URL=https://your-gateway.example/v1
LLM_API_KEY=
LLM_MODEL=gpt-5.4-mini
VISION_MODEL=gpt-5.4-mini

# --- Image generation (OpenAI-compatible images endpoint) ---
IMAGE_BASE_URL=https://your-gateway.example/v1
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2

# --- Web search for enrichment (Tavily). Optional: without it, /enrich
#     degrades to source-less model knowledge. ---
TAVILY_API_KEY=

# --- Product data source (read-only). Postgres or MySQL DSN. Leave blank to
#     use the built-in 3-SKU mock database. ---
DATABASE_URL=
# PRODUCTS_TABLE=            # optional: force a table instead of auto-detect

# --- Optional overrides ---
# HTTP_USER_AGENT=          # some gateways behind Cloudflare block the default SDK UA
# COST_PER_IMAGE=0.04       # cost-estimate rates for the observability block
# COST_PER_1K_TOKENS=0.0006
