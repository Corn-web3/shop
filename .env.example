# Copy to .env and fill in. The service STARTS WITHOUT any of these (mock DB +
# offline/degraded fallbacks); key-dependent endpoints return clear notes.
# Reviewers run with their own keys.

# --- LLM (copy + vision critic + research extraction), OpenAI-compatible ---
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-5.4-mini
VISION_MODEL=gpt-5.4-mini

# --- Image generation (OpenAI-compatible images endpoint) ---
IMAGE_BASE_URL=
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2

# --- Optional. Some OpenAI-compatible gateways sit behind Cloudflare and block
#     the default SDK User-Agent ("Your request was blocked"). A browser UA is
#     sent by default; override here only if a gateway needs something specific. ---
HTTP_USER_AGENT=

# --- Web search for Tier 1 enrichment (Tavily). Without it, /enrich degrades
#     to clearly-flagged, source-less model knowledge. ---
TAVILY_API_KEY=

# --- Read-only SSB database (provided by reviewers). Without it, a built-in
#     mock of 3 SKUs is used. The scheme selects the adapter:
#       MySQL (the real SSB DB):  mysql://user:pass@host:3306/boxing
#       Postgres:                 postgresql://user:pass@host:5432/db
#     Percent-encode special chars in the password (@ -> %40). Read-only.
#     PRODUCTS_TABLE is an optional Postgres table override (MySQL uses fbm_sku).
DATABASE_URL=
PRODUCTS_TABLE=
